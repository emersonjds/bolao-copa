# Headers do deploy estático (Netlify e Cloudflare honram este arquivo; o Next
# copia public/_headers -> out/_headers no export).

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # CSP: 'unsafe-inline' em script/style é necessário no static export do Next
  # (sem servidor não há nonce). connect-src libera Supabase (REST + Realtime);
  # img-src libera bandeiras (flagcdn) e avatares do Google.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://flagcdn.com https://lh3.googleusercontent.com; font-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# HTML: cache curto + revalidação em segundo plano (conteúdo pode mudar a cada deploy).
/*.html
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

# Assets com hash no nome são imutáveis: cache agressivo.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
