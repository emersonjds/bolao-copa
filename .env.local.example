# Fonte de dados do app.
#
# Enquanto o backend não existe, o MSW (Mock Service Worker) é a fonte de dados
# e fica LIGADO por padrão — em dev e também no deploy estático de produção.
# Copie este arquivo para .env.local para sobrescrever. NUNCA commite o
# .env.local — está no .gitignore.

# URL base do backend real (BFF). Vazio = chamadas relativas /api/* atendidas
# pelo MSW. Defina quando o backend subir.
# NEXT_PUBLIC_API_URL=https://api.bolaodacopa.app

# Desligue o MSW para passar a usar a API real acima.
# NEXT_PUBLIC_ENABLE_MSW=false

# --- Supabase (backend real) ---
# Preencha em .env.local quando o projeto Supabase existir. NUNCA commite valores.
# A publishable key é pública por design (protegida por RLS); a secret key
# (service_role) NUNCA vai para o frontend — só em Edge Functions.
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<...>
