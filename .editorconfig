# EditorConfig — https://editorconfig.org
# Garante consistência de formatação entre editores e IDEs (VS Code, IntelliJ, Vim, etc.)
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Markdown: dois espaços no final de linha criam <br>, não cortar
trim_trailing_whitespace = false
max_line_length = off

[*.{json,jsonc}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{png,jpg,jpeg,gif,ico,svg,woff,woff2,ttf,eot}]
# Arquivos binários — ignorar regras de texto
insert_final_newline = false
trim_trailing_whitespace = false
